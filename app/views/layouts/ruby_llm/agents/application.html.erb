        --c-purple-50: 250 245 255; --c-purple-100: 243 232 255; --c-purple-200: 233 213 255;
        --c-purple-300: 216 180 254; --c-purple-400: 192 132 252; --c-purple-500: 168 85 247;
        --c-purple-600: 147 51 234; --c-purple-700: 126 34 206; --c-purple-800: 107 33 168;
        --c-purple-900: 88 28 135; --c-purple-950: 59 7 100;
        /* Cyan */
        --c-cyan-50: 236 254 255; --c-cyan-100: 207 250 254; --c-cyan-200: 165 243 252;
        --c-cyan-300: 103 232 249; --c-cyan-400: 34 211 238; --c-cyan-500: 6 182 212;
        --c-cyan-600: 8 145 178; --c-cyan-700: 14 116 144; --c-cyan-800: 21 94 117;
        --c-cyan-900: 22 78 99; --c-cyan-950: 8 51 68;
        /* Pink */
        --c-pink-50: 253 242 248; --c-pink-100: 252 231 243; --c-pink-200: 251 207 232;
        --c-pink-300: 249 168 212; --c-pink-400: 244 114 182; --c-pink-500: 236 72 153;
        --c-pink-600: 219 39 119; --c-pink-700: 190 24 93; --c-pink-800: 157 23 77;
        --c-pink-900: 131 24 67; --c-pink-950: 80 7 36;
        /* Amber */
        --c-amber-50: 255 251 235; --c-amber-100: 254 243 199; --c-amber-200: 253 230 138;
        --c-amber-300: 252 211 77; --c-amber-400: 251 191 36; --c-amber-500: 245 158 11;
        --c-amber-600: 217 119 6; --c-amber-700: 180 83 9; --c-amber-800: 146 64 14;
        --c-amber-900: 120 53 15; --c-amber-950: 69 26 3;
      }
      .dark {
        /* Gray → Gruvbox bg/fg */
        --c-gray-50: 251 241 199; --c-gray-100: 235 219 178; --c-gray-200: 213 196 161;
        --c-gray-300: 189 174 147; --c-gray-400: 189 174 147; --c-gray-500: 168 153 132;
        --c-gray-600: 146 131 116; --c-gray-700: 102 92 84; --c-gray-800: 80 73 69;
        --c-gray-900: 60 56 54; --c-gray-950: 40 40 40;
        /* Blue → Gruvbox aqua (#83a598 / #458588) */
        --c-blue-50: 195 215 205; --c-blue-100: 174 199 188; --c-blue-200: 153 182 170;
        --c-blue-300: 131 165 152; --c-blue-400: 100 149 144; --c-blue-500: 69 133 136;
        --c-blue-600: 58 112 115; --c-blue-700: 48 93 95; --c-blue-800: 38 73 75;
        --c-blue-900: 28 55 57; --c-blue-950: 20 40 42;
        /* Red → Gruvbox red (#fb4934 / #cc241d) */
        --c-red-50: 253 165 155; --c-red-100: 253 135 122; --c-red-200: 252 104 87;
        --c-red-300: 251 73 52; --c-red-400: 228 55 41; --c-red-500: 251 89 66;
        --c-red-600: 204 36 29; --c-red-700: 136 24 19; --c-red-800: 102 18 14;
        --c-red-900: 72 12 10; --c-red-950: 50 8 7;
        /* Green → Gruvbox green (#b8bb26 / #98971a) */
        --c-green-50: 225 227 145; --c-green-100: 213 215 112; --c-green-200: 199 201 75;
        --c-green-300: 184 187 38; --c-green-400: 168 169 32; --c-green-500: 152 151 26;
        --c-green-600: 126 125 22; --c-green-700: 101 100 17; --c-green-800: 77 77 13;
        --c-green-900: 55 55 9; --c-green-950: 38 38 6;
        /* Yellow → Gruvbox yellow (#fabd2f / #d79921) */
        --c-yellow-50: 253 225 155; --c-yellow-100: 252 215 121; --c-yellow-200: 251 202 84;
        --c-yellow-300: 250 189 47; --c-yellow-400: 233 171 40; --c-yellow-500: 215 153 33;
        --c-yellow-600: 179 127 27; --c-yellow-700: 143 102 22; --c-yellow-800: 109 78 17;
        --c-yellow-900: 77 55 12; --c-yellow-950: 53 38 8;
        /* Orange → Gruvbox orange (#fe8019 / #d65d0e) */
        --c-orange-50: 255 197 140; --c-orange-100: 255 172 102; --c-orange-200: 254 150 64;
        --c-orange-300: 254 128 25; --c-orange-400: 234 111 20; --c-orange-500: 214 93 14;
        --c-orange-600: 178 77 12; --c-orange-700: 142 62 9; --c-orange-800: 108 47 7;
        --c-orange-900: 76 33 5; --c-orange-950: 52 23 3;
        /* Purple → Gruvbox purple (#d3869b / #b16286) */
        --c-purple-50: 235 186 200; --c-purple-100: 227 168 184; --c-purple-200: 219 151 170;
        --c-purple-300: 211 134 155; --c-purple-400: 194 116 145; --c-purple-500: 177 98 134;
        --c-purple-600: 147 81 111; --c-purple-700: 118 65 89; --c-purple-800: 90 50 68;
        --c-purple-900: 63 35 48; --c-purple-950: 43 24 33;
        /* Cyan → Gruvbox green-cyan (#8ec07c / #689d6a) */
        --c-cyan-50: 194 228 184; --c-cyan-100: 177 216 164; --c-cyan-200: 160 204 144;
        --c-cyan-300: 142 192 124; --c-cyan-400: 123 175 115; --c-cyan-500: 104 157 106;
        --c-cyan-600: 86 131 88; --c-cyan-700: 69 105 70; --c-cyan-800: 53 80 54;
        --c-cyan-900: 37 57 38; --c-cyan-950: 26 40 27;
        /* Pink → Gruvbox purple (no pink in Gruvbox) */
        --c-pink-50: 235 186 200; --c-pink-100: 227 168 184; --c-pink-200: 219 151 170;
        --c-pink-300: 211 134 155; --c-pink-400: 194 116 145; --c-pink-500: 177 98 134;
        --c-pink-600: 147 81 111; --c-pink-700: 118 65 89; --c-pink-800: 90 50 68;
        --c-pink-900: 63 35 48; --c-pink-950: 43 24 33;
        /* Amber → Gruvbox yellow-orange */
        --c-amber-50: 254 224 155; --c-amber-100: 253 213 121; --c-amber-200: 252 198 84;
        --c-amber-300: 251 184 47; --c-amber-400: 235 162 37; --c-amber-500: 215 140 26;
        --c-amber-600: 179 116 22; --c-amber-700: 143 93 17; --c-amber-800: 109 71 13;
        --c-amber-900: 77 50 9; --c-amber-950: 53 35 6;
      }
    </style>

    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
      tailwind.config = {
        darkMode: 'class',
        theme: {
          extend: {
            colors: (function() {
              var families = ['gray','blue','red','green','yellow','orange','purple','cyan','pink','amber'];
              var shades = [50,100,200,300,400,500,600,700,800,900,950];
              var c = {};
              families.forEach(function(f) {
                c[f] = {};
                shades.forEach(function(s) {
                  c[f][s] = 'rgb(var(--c-' + f + '-' + s + ') / <alpha-value>)';
                });
              });
              return c;
            })()
          }
        }
      }
    </script>

    <!-- Highcharts for charts (primary CDN, fallback to jsDelivr) -->
    <script src="https://code.highcharts.com/highcharts.js"
            onerror="var s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/highcharts@11.4.0/highcharts.min.js';s.onload=window.__initHighchartsDefaults;document.head.appendChild(s);"></script>

    <!-- Chart color helpers + Highcharts defaults -->
    <script>
      function chartColor(lightHex, darkHex) {
        return document.documentElement.classList.contains('dark') ? darkHex : lightHex;
      }
      function chartColorAlpha(lightRgba, darkR, darkG, darkB, alpha) {
        return document.documentElement.classList.contains('dark')
          ? 'rgba(' + darkR + ',' + darkG + ',' + darkB + ',' + alpha + ')' : lightRgba;
      }
      window.__initHighchartsDefaults = function() {
        if (typeof Highcharts === 'undefined') return;
        Highcharts.setOptions({
          credits: { enabled: false },
          chart: {
            backgroundColor: 'transparent',
            style: { fontFamily: 'ui-monospace, monospace' }
          },
          title: { text: null },
          xAxis: {
            labels: { style: { color: chartColor('#6B7280', '#928374') } },
            lineColor: chartColorAlpha('rgba(107, 114, 128, 0.1)', 146, 131, 116, 0.1),
            tickColor: chartColorAlpha('rgba(107, 114, 128, 0.1)', 146, 131, 116, 0.1)
          },
          yAxis: {
            labels: { style: { color: chartColor('#6B7280', '#928374') } },
            gridLineColor: chartColorAlpha('rgba(107, 114, 128, 0.1)', 146, 131, 116, 0.1)
          },
          legend: {
            itemStyle: { color: chartColor('#6B7280', '#928374') },
            itemHoverStyle: { color: chartColor('#9CA3AF', '#bdae93') }
          },
          tooltip: {
            backgroundColor: chartColorAlpha('rgba(0, 0, 0, 0.85)', 40, 40, 40, 0.95),
            borderColor: 'transparent',
            style: { color: chartColor('#E5E7EB', '#ebdbb2'), fontFamily: 'ui-monospace, monospace' }
          }
        });
      };
      window.__initHighchartsDefaults();
    </script>

    <!-- Alpine.js -->
    <script
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"
    ></script>

    <style>[x-cloak] { display: none !important; }</style>

    <!-- Clickable rows -->
    <script type="module">
      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[data-href]').forEach(function(element) {
          element.addEventListener('click', function(e) {
            if (e.target.closest('a, button')) return;
            window.location = element.dataset.href;
          });
        });
      });
    </script>

    <!-- Theme Switcher (Alpine.js) -->
    <script>
      function themeManager() {
        return {
          preference: localStorage.getItem('ruby_llm_agents_theme') || 'auto',
          init() {
            this.applyTheme();
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
              if (this.preference === 'auto') this.applyTheme();
            });
          },
          setTheme(value) {
            this.preference = value;
            localStorage.setItem('ruby_llm_agents_theme', value);
            this.applyTheme();
          },
          applyTheme() {
            const isDark = this.preference === 'dark' ||
              (this.preference === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.toggle('dark', isDark);
          }
        };
      }
    </script>

    <style type="text/tailwindcss">
    .badge {
      @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium;
    }
    .badge-running {
      @apply bg-blue-100 dark:bg-blue-500/20 text-blue-700 dark:text-blue-300;
    }
    .badge-success {
      @apply bg-green-100 dark:bg-green-500/20 text-green-700 dark:text-green-300;
    }
    .badge-error {
      @apply bg-red-100 dark:bg-red-500/20 text-red-700 dark:text-red-300;
    }
    .badge-timeout {
      @apply bg-yellow-100 dark:bg-yellow-500/20 text-yellow-700 dark:text-yellow-300;
    }
    .badge-cyan {
      @apply bg-cyan-100 dark:bg-cyan-500/20 text-cyan-700 dark:text-cyan-300;
    }
    .badge-purple {
      @apply bg-purple-100 dark:bg-purple-500/20 text-purple-700 dark:text-purple-300;
    }
    .badge-orange {
      @apply bg-orange-100 dark:bg-orange-500/20 text-orange-700 dark:text-orange-300;
    }
    .badge-sm {
      @apply inline-flex items-center px-1.5 py-px rounded-full text-[10px] font-medium;
    }
    </style>
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 min-h-screen flex flex-col font-sans">
    <!-- Header -->
    <header class="border-b border-gray-200 dark:border-gray-800" x-data="{ mobileMenuOpen: false }">
      <div class="max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 h-12 flex items-center">
        <!-- Brand -->
        <%= link_to ruby_llm_agents.root_path, class: "font-mono text-sm font-medium text-gray-900 dark:text-gray-100 hover:text-gray-600 dark:hover:text-gray-400 transition-colors" do %>
          ruby_llm<span class="text-gray-400 dark:text-gray-600">::</span>agents
        <% end %>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center ml-8 gap-0.5 font-mono text-xs">
          <% nav_items = [
            [ruby_llm_agents.root_path, "dashboard"],
            [ruby_llm_agents.agents_path, "agents"],
            [ruby_llm_agents.executions_path, "executions"]
          ]
          nav_items << [ruby_llm_agents.tenants_path, "tenants"] if tenant_filter_enabled?
          nav_items.each do |path, label| %>
            <% active = current_page?(path) %>
            <%= link_to label, path, class: "px-2.5 py-1 rounded transition-colors #{active ? 'text-gray-900 dark:text-gray-100 bg-gray-100 dark:bg-gray-800' : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300'}" %>
          <% end %>
        </nav>

        <!-- Right Side -->
        <div class="ml-auto flex items-center gap-1">
          <%= link_to ruby_llm_agents.system_config_path, class: "hidden md:flex p-1.5 text-gray-400 dark:text-gray-600 hover:text-gray-700 dark:hover:text-gray-300 rounded transition-colors", title: "Config" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          <% end %>

          <!-- Mobile menu button -->
          <button
            type="button"
            @click="mobileMenuOpen = !mobileMenuOpen"
            :aria-expanded="mobileMenuOpen"
            class="md:hidden p-1.5 text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 rounded transition-colors"
          >
            <span class="sr-only">Open main menu</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Navigation -->
      <div
        x-show="mobileMenuOpen"
        x-cloak
        x-transition:enter="transition ease-out duration-150"
        x-transition:enter-start="opacity-0 -translate-y-1"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-100"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 -translate-y-1"
        @click.outside="mobileMenuOpen = false"
        class="md:hidden border-t border-gray-200 dark:border-gray-800"
      >
        <nav class="max-w-7xl mx-auto px-4 py-2 font-mono text-xs space-y-0.5">
          <% mobile_nav_items = [
            [ruby_llm_agents.root_path, "dashboard"],
            [ruby_llm_agents.agents_path, "agents"],
            [ruby_llm_agents.executions_path, "executions"]
          ]
          mobile_nav_items << [ruby_llm_agents.tenants_path, "tenants"] if tenant_filter_enabled?
          mobile_nav_items.each do |path, label| %>
            <% active = current_page?(path) %>
            <%= link_to label, path, class: "block px-3 py-2 rounded transition-colors #{active ? 'text-gray-900 dark:text-gray-100 bg-gray-100 dark:bg-gray-800' : 'text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300'}" %>
          <% end %>
          <div class="border-t border-gray-200 dark:border-gray-800 my-1.5"></div>
          <%= link_to "config", ruby_llm_agents.system_config_path, class: "block px-3 py-2 rounded text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 flex-1">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 mt-auto" x-data="themeManager()">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <div class="flex items-center justify-between font-mono text-[10px] text-gray-400 dark:text-gray-600 uppercase tracking-widest">
          <div class="flex items-center gap-1">
            <button @click="setTheme('light')" :class="preference === 'light' && 'text-gray-700 dark:text-gray-300'" class="px-1.5 py-0.5 rounded hover:text-gray-600 dark:hover:text-gray-400 transition-colors">light</button>
            <span class="text-gray-300 dark:text-gray-700">&middot;</span>
            <button @click="setTheme('dark')" :class="preference === 'dark' && 'text-gray-700 dark:text-gray-300'" class="px-1.5 py-0.5 rounded hover:text-gray-600 dark:hover:text-gray-400 transition-colors">dark</button>
            <span class="text-gray-300 dark:text-gray-700">&middot;</span>
            <button @click="setTheme('auto')" :class="preference === 'auto' && 'text-gray-700 dark:text-gray-300'" class="px-1.5 py-0.5 rounded hover:text-gray-600 dark:hover:text-gray-400 transition-colors">auto</button>
          </div>
          <a href="https://github.com/adham90/ruby_llm-agents" class="hover:text-gray-600 dark:hover:text-gray-400 transition-colors normal-case tracking-normal">ruby_llm-agents</a>
        </div>
      </div>
    </footer>
  </body>
</html>
